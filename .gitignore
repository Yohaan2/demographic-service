# ==============================================================================
# Environment
# ==============================================================================
# NOTE: .env is intentionally NOT ignored here because it contains
# production configuration (MODEL_TYPE, paths, etc.) that should be
# versioned. If you have secrets, use a separate .env.secrets file
# and add it to this ignore list.
# .env
.env
.env.local
.env.*.local

node_modules/

upload/
