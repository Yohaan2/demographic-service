# ==============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - DEMOGRAPHIC SERVICE
# ==============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno de despliegue.

# --- Configuración del Servidor ---
HOST=0.0.0.0
PORT=8000
WORKERS=4

# --- Modelos y Estrategias de IA ---
MODEL_TYPE=mivolo
DETECTOR=scrfd

# --- Rutas de los Modelos ONNX ---
# Los archivos deben estar en models/weights/ en el host
DETECTOR_MODEL_PATH=models/weights/scrfd_2.5g_bnkps.onnx
AGE_GENDER_MODEL_PATH=models/weights/mivolo_model.onnx

# --- Configuración de Tracking ---
MAX_TRACKERS=500
TRACKER_TTL=300

# --- Configuración de Agregación Temporal ---
AGGREGATION_WINDOW=10

# --- Control de Carga y Backpressure ---
MAX_PENDING_REQUESTS=500

# --- Configuración de Recorte Facial ---
CROP_SIZE=224

# --- Nivel de Logging ---
LOG_LEVEL=INFO
